# Which LLM backend generate_explanations.py / evaluate_typology_accuracy.py use.
# Swapping this value is the entire swap - no code changes required.
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Used when LLM_PROVIDER=ollama - Ollama's OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Postgres (infra/docker-compose.yml). Use `localhost` when running api/ directly
# on the host; use the `postgres` service name once api/ itself runs in Docker.
DATABASE_URL=postgresql://anomaly:anomaly@localhost:5432/anomaly_detection
